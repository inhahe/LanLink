<Window x:Class="LanLink.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LanLink"
        Title="LanLink" Height="620" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================================ -->
        <!-- LEFT PANEL : peers + connect-remote                          -->
        <!-- ============================================================ -->
        <Border Grid.Column="0" Background="White" CornerRadius="8"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <DockPanel Margin="12">
                <TextBlock DockPanel.Dock="Top" Text="Peers"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <!-- Connect to remote -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <TextBlock Text="Remote address:" FontSize="11" Foreground="#6B7280"
                               Margin="0,0,0,3"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RemoteAddressBox" Grid.Column="0"
                                 Padding="6,4" FontSize="12"
                                 KeyDown="RemoteBox_KeyDown"/>
                        <Button  x:Name="ConnectBtn" Grid.Column="1"
                                 Content="Connect" Padding="10,4"
                                 Margin="6,0,0,0" Click="ConnectRemote_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Peer list -->
                <ListBox x:Name="PeerList" BorderThickness="0"
                         SelectionChanged="PeerList_SelectionChanged"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="RemovePeerMenuItem"
                                      Header="Remove peer"
                                      Click="RemovePeer_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="10" Height="10"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#9CA3AF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="13"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Name}"/>
                                            <Setter Property="Foreground" Value="#111827"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="2"
                                           FontSize="10" Foreground="#9CA3AF"
                                           VerticalAlignment="Center" Margin="6,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding RouteLabel}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                    <Setter Property="Text" Value="Offline"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- RIGHT PANEL : activity log + send controls                   -->
        <!-- ============================================================ -->
        <Border Grid.Column="2" Background="White" CornerRadius="8"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <DockPanel Margin="12">

                <TextBlock DockPanel.Dock="Top" Text="Activity"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <!-- Send controls (docked bottom) -->
                <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- "Sending to" label -->
                    <TextBlock x:Name="SelectedPeerLabel" Grid.Row="0"
                               Text="Select a peer to send" FontSize="12"
                               Foreground="#6B7280" Margin="0,0,0,6"/>

                    <!-- Text input -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="MessageBox" Grid.Column="0"
                                 Padding="8,5" FontSize="13"
                                 IsEnabled="False"
                                 KeyDown="MessageBox_KeyDown"/>
                        <Button x:Name="SendTextBtn" Grid.Column="1"
                                Content="Send" Padding="16,5"
                                Margin="8,0,0,0" IsEnabled="False"
                                Click="SendText_Click"/>
                    </Grid>

                    <!-- File / folder / settings buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="SendFileBtn" Content="Send File"
                                Padding="12,5" IsEnabled="False"
                                Click="SendFile_Click"/>
                        <Button x:Name="SendFolderBtn" Content="Send Folder"
                                Padding="12,5" Margin="8,0,0,0" IsEnabled="False"
                                Click="SendFolder_Click"/>

                        <!-- spacer -->
                        <Border Width="1"/>

                        <Button Content="Settings" Padding="12,5"
                                Margin="8,0,0,0" Click="Settings_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Activity log -->
                <ListBox x:Name="ActivityLog" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy message"
                                      Click="CopyMessage_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock local:LinkBehavior.FormattedText="{Binding Display}"
                                       TextWrapping="Wrap"
                                       Margin="2,1" FontSize="12.5">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#6B7280"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Level}" Value="TextReceived">
                                                <Setter Property="Foreground" Value="#2563EB"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="TextSent">
                                                <Setter Property="Foreground" Value="#16A34A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="Transfer">
                                                <Setter Property="Foreground" Value="#7C3AED"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
